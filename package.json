{
  "name": "nerima-open-data-mcp",
  "version": "0.1.0",
  "description": "MCP server for Nerima City open data.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "import:open-data": "node dist/scripts/importOpenData.js",
    "import:open-data:dev": "tsx src/scripts/importOpenData.ts",
    "scheduler:import": "node dist/scripts/scheduledImport.js"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.21.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "csv-parse": "^7.0.0",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "iconv-lite": "^0.7.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.11",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  },
  "overrides": {
    "uuid": "^11.1.0"
  }
}
